DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codelight
MASTER_SECRET=change-me-to-a-random-64-char-hex-string
PORT=3006
NODE_ENV=production
TOKEN_EXPIRY_DAYS=30

# APNs push notifications (optional — pushes won't work without these)
# APNS_KEY_ID=your-key-id
# APNS_TEAM_ID=your-team-id
# APNS_BUNDLE_ID=com.codelight.app
# Or place the .p8 file as apns-key.p8 in the project root (preferred over base64 env var)
# APNS_KEY=base64-encoded-p8-key-content
