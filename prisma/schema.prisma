generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id         String    @id @default(cuid())
  publicKey  String    @unique
  name       String
  kind       String    @default("ios") // 'ios' | 'mac'
  shortCode  String?   @unique // Permanent 6-char pairing code for Macs (lazy-generated)
  seq        Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Last time this device successfully authenticated (HTTP middleware
  /// or socket handshake). Used by `notifyLinkedIPhones` to filter out
  /// stale devices whose JWT has expired but whose APNs token is still
  /// technically valid — without this the server keeps pushing to dead
  /// installs forever.
  lastSeenAt DateTime?

  // Notification preferences (only meaningful for iOS devices).
  // `notificationsEnabled` is the master kill-switch — when false, the server
  // skips ALL push delivery for this device regardless of the per-kind flags
  // below. Existing devices default to true so the upgrade is silent.
  notificationsEnabled Boolean @default(true)
  notifyOnCompletion   Boolean @default(false) // non-ended → ended
  notifyOnApproval     Boolean @default(false) // tool waiting_approval
  notifyOnError        Boolean @default(false) // tool status=error

  // Subscription / trial fields. Mac devices ignore these (server skips
  // enforcement for kind='mac'); iOS devices start at 'none', flip to
  // 'trial' after first pairing, and 'active' after a verified IAP.
  subscriptionStatus    String    @default("none")
  trialStartedAt        DateTime?
  trialExpiresAt        DateTime?
  trialExpireNotifiedAt DateTime?

  sessions      Session[]
  pushTokens    PushToken[]
  launchPresets LaunchPreset[]
  knownProjects KnownProject[]

  // Device linking (paired devices can see each other's sessions)
  linksAsSource DeviceLink[] @relation("LinkSource")
  linksAsTarget DeviceLink[] @relation("LinkTarget")
}

/// Links two devices together (bidirectional access).
/// Created during QR pairing. Both devices can see each other's sessions.
model DeviceLink {
  id             String   @id @default(cuid())
  sourceDeviceId String
  targetDeviceId String
  sourceDevice   Device   @relation("LinkSource", fields: [sourceDeviceId], references: [id])
  targetDevice   Device   @relation("LinkTarget", fields: [targetDeviceId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([sourceDeviceId, targetDeviceId])
  // Single-column indexes for the OR(source=X, target=X) lookups in
  // getAccessibleDeviceIds + canAccessSession + notifyLinkedIPhones. The
  // composite unique above can't serve either column alone, so without these
  // every socket message did a full DeviceLink scan.
  @@index([sourceDeviceId])
  @@index([targetDeviceId])
}

model Session {
  id              String   @id @default(cuid())
  tag             String
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  metadata        String
  metadataVersion Int      @default(0)
  seq             Int      @default(0)
  active          Boolean  @default(true)
  lastActiveAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages SessionMessage[]

  @@unique([deviceId, tag])
  @@index([deviceId, updatedAt(sort: Desc)])
}

model SessionMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  localId   String?
  seq       Int
  content   String
  createdAt DateTime @default(now())

  @@unique([sessionId, localId])
  @@index([sessionId, seq])
}

model PairingRequest {
  id               String   @id @default(cuid())
  tempPublicKey    String   @unique
  shortCode        String?  @unique // 6-char human-readable pairing code
  serverUrl        String
  deviceName       String
  response         String?
  responseDeviceId String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@index([tempPublicKey])
  @@index([shortCode])
}

/// Launch presets for a Mac MioIsland device.
/// iPhone fetches these to show the user what commands can be remote-launched.
model LaunchPreset {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  name      String
  command   String
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId, sortOrder])
}

/// Known project paths for a Mac MioIsland device.
/// Mac uploads its session cwds + recent project list; iPhone uses these
/// when picking a project for a remote-launched session.
model KnownProject {
  id         String   @id @default(cuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  path       String
  name       String
  lastSeenAt DateTime @default(now())

  @@unique([deviceId, path])
  @@index([deviceId, lastSeenAt(sort: Desc)])
}

model PushToken {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id])
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, token])
}

/// Live Activity push token (scoped to a session).
/// iOS generates a token per active Live Activity.
model LiveActivityToken {
  id        String   @id @default(cuid())
  deviceId  String
  sessionId String
  token     String // APNs push token for this specific activity
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, sessionId])
  @@index([sessionId])
}

/// One row per StoreKit 2 originalTransactionId. Holds the trial/active
/// state independent of any single device, so a paid Apple ID can move
/// across devices without losing entitlement.
model Subscription {
  id                    String    @id @default(cuid())
  originalTransactionId String    @unique
  status                String    @default("active") // 'trial' | 'active' | 'expired' | 'revoked'
  trialStartedAt        DateTime?
  trialExpiresAt        DateTime?
  paidAt                DateTime?
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  devices SubscriptionDevice[]
}

/// Join table — many devices can share one Subscription (same Apple ID).
model SubscriptionDevice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  deviceId       String
  createdAt      DateTime     @default(now())

  @@unique([subscriptionId, deviceId])
  @@index([deviceId])
}

/// Promotional / referral codes that grant a fixed-duration trial.
model RedeemCode {
  id           String    @id @default(cuid())
  code         String    @unique
  durationDays Int       @default(30)
  maxUses      Int       @default(1)
  usedCount    Int       @default(0)
  createdBy    String?
  note         String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  usages RedeemCodeUsage[]
}

/// Tracks which device redeemed which code, with the resulting grant window.
model RedeemCodeUsage {
  id           String     @id @default(cuid())
  redeemCodeId String
  redeemCode   RedeemCode @relation(fields: [redeemCodeId], references: [id])
  deviceId     String
  grantedUntil DateTime
  createdAt    DateTime   @default(now())

  @@unique([redeemCodeId, deviceId])
  @@index([deviceId])
}
